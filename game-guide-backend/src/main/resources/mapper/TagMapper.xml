<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gameguide.mapper.TagMapper">

    <resultMap id="BaseResultMap" type="com.gameguide.entity.Tag">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
    </resultMap>

    <insert id="insert" parameterType="com.gameguide.entity.Tag" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tag (name)
        VALUES (#{name})
    </insert>

    <update id="update" parameterType="com.gameguide.entity.Tag">
        UPDATE tag
        SET name = #{name}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM tag WHERE id = #{id}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT id, name
        FROM tag
        WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT id, name
        FROM tag
        ORDER BY id DESC
    </select>

    <select id="selectByGuideId" resultMap="BaseResultMap">
        SELECT t.id, t.name
        FROM tag t
        INNER JOIN guide_tag gt ON t.id = gt.tag_id
        WHERE gt.guide_id = #{guideId}
    </select>

</mapper>

